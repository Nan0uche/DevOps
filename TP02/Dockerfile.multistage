FROM golang:1.22-alpine AS build

WORKDIR /app
COPY go.mod ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /server .

FROM alpine:3.20

WORKDIR /app
RUN adduser -D -u 10001 appuser
COPY --from=build /server ./server
COPY --from=build /app/web ./web

USER appuser

ENV PING_LISTEN_PORT=8080
EXPOSE 8080

CMD ["./server"]
